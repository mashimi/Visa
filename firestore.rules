rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can only access interview sessions they own
    match /interviewSessions/{sessionId} {
      allow read, update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      // Evaluations subcollection - scoped to session owner
      match /evaluations/{evalId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/interviewSessions/$(sessionId)).data.userId == request.auth.uid;
      }
    }

    // Users can only access messages within sessions they own
    match /interviewMessages/{messageId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/interviewSessions/$(resource.data.sessionId)) &&
        get(/databases/$(database)/documents/interviewSessions/$(resource.data.sessionId)).data.userId == request.auth.uid;
    }

    // Users can only access documents they own
    match /documents/{documentId} {
      allow read, write: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // caseFiles - the Project Embassy orchestrator collection
    match /caseFiles/{caseId} {
      allow read, update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      // No delete allowed
    }

  }
}
